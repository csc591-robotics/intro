# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real secrets.

# ── LLM provider configuration ────────────────────────────────────────────────
# LLM_PROVIDER: the LangChain provider name.
# LLM_MODEL:    the model identifier for that provider.
#
# Examples:
#   OpenAI        → LLM_PROVIDER=openai        LLM_MODEL=gpt-4o
#   Anthropic     → LLM_PROVIDER=anthropic      LLM_MODEL=claude-3-5-sonnet-20241022
#   Mistral       → LLM_PROVIDER=mistralai      LLM_MODEL=mistral-large-latest
#   Ollama (local)→ LLM_PROVIDER=ollama         LLM_MODEL=llama3.2
#
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ── Provider API key ───────────────────────────────────────────────────────────
# Set the key that matches your chosen provider.
# LangChain picks up the standard env var name for each provider automatically.
#
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# MISTRAL_API_KEY=your_mistral_api_key_here
# (Ollama runs locally — no API key needed)

# ── Provider package ──────────────────────────────────────────────────────────
# Install the matching LangChain integration package inside the container:
#   pip install langchain-openai      (OpenAI / Azure)
#   pip install langchain-anthropic   (Anthropic)
#   pip install langchain-mistralai   (Mistral)
#   pip install langchain-ollama      (Ollama)
